#
# Hardware target: H100-80GB.
# Shared across all configs (vllm-serve, vllm-serve-ec, dynamo-fd, dynamo-fd-ec).
# TP=2 — each worker pod requests 2 GPUs; the target node needs ≥ 2 free H100s.
#
# BEFORE FIRST USE: replace <FILL-IN-H100-HOSTNAME> with the
# kubernetes.io/hostname of the target node:
#
#   kubectl get nodes -L nvidia.com/gpu.product | awk '/H100/'

export VLLM_IMAGE="nvcr.io/nvidia/ai-dynamo/vllm-runtime:1.1.0"
export HW_NODE_SELECTOR='{"kubernetes.io/hostname":"<FILL-IN-H100-HOSTNAME>"}'
export HW_TOLERATIONS='[]'
