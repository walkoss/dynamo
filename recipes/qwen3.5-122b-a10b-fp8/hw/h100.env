#
# Hardware target: H100.
# Shared by all three configs (vllm-serve, dynamo-fd, dynamo-fd-ec) —
# pinning to one specific hostname so they all benchmark on identical hardware.
#
# NOTE: TP=2 — each worker pod requests 2 GPUs. The target node must have
# at least 4 free H100s (2 for vllm-serve/worker + 2 spare, or 2 for each
# DGD VllmWorker). Find candidates via:
#
#   kubectl get nodes -L nvidia.com/gpu.product | awk '/H100/'
#
# BEFORE FIRST USE: replace <FILL-IN-H100-HOSTNAME> with the
# kubernetes.io/hostname of the target H100 node.

# Multi-arch manifest — same tag works on amd64 (H100) and arm64 (GB200).
export VLLM_IMAGE="nvcr.io/nvidia/ai-dynamo/vllm-runtime:1.1.0"

export HW_NODE_SELECTOR='{"kubernetes.io/hostname":"ip-100-66-190-59.ec2.internal"}'

# H100 nodes carry no special taint — empty toleration array.
export HW_TOLERATIONS='[]'
