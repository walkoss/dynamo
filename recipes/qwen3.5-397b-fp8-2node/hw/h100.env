#
# Hardware target: H100 (aws-dev-02 8x p5.48xlarge fleet, NVIDIA-H100-80GB-HBM3).
#
# This recipe has TWO node-selection axes:
#
#   1. HW_NODE_SELECTOR
#      Used by deploy/dynamo.yaml's VllmWorker pods.
#      A GPU-product label (not a hostname pin) — Kubernetes picks two
#      H100 nodes with 8 free GPUs each. topologySpreadConstraints in
#      the DGD forces the 2 worker replicas onto distinct hostnames.
#
#   2. HW_NODE_SELECTOR_VLLM_SERVE
#      Used by deploy/vllm-serve.yaml only.
#      A hostname pin so the user can deliberately steer the baseline
#      onto a specific 8-GPU node that won't conflict with the 2-node
#      Dynamo deploy.
#
#      BEFORE FIRST USE: replace <FILL-IN-H100-HOSTNAME> with the
#      kubernetes.io/hostname of the target H100 node. List candidates:
#
#        kubectl get nodes -L nvidia.com/gpu.product \
#          | awk '/H100-80GB-HBM3/'
#
#      To pick a free one, see README.md → "Capacity precheck".

# Multi-arch manifest — KV-router pattern verified on 1.1.1.
export VLLM_IMAGE="nvcr.io/nvidia/ai-dynamo/vllm-runtime:1.1.1"

# JSON-flow value (single line) so envsubst can drop it inline into
# YAML without indentation gymnastics.
export HW_NODE_SELECTOR='{"nvidia.com/gpu.product":"NVIDIA-H100-80GB-HBM3"}'

# Single hostname for the vllm-serve baseline only.
export HW_NODE_SELECTOR_VLLM_SERVE='{"kubernetes.io/hostname":"<FILL-IN-H100-HOSTNAME>"}'

# H100 nodes on aws-dev-02 carry no special taint — empty toleration array.
export HW_TOLERATIONS='[]'
